---
layout: none
permalink: /site.webmanifest
---
{
  "name": "{{ site.webmanifest.name | default: site.title }}",
  "short_name": "{{ site.webmanifest.short_name | default: site.title }}",
  "icons": {{ site.webmanifest.icons | default: site.default_manifest_icons | jsonify }},
  "theme_color": "{{ site.webmanifest.theme_color | default: '#ffffff' }}",
  "background_color": "{{ site.webmanifest.background_color | default: '#ffffff' }}",
  "display": "{{ site.webmanifest.display | default: 'standalone' }}"
}
